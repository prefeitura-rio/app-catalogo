{
  "openapi": "3.0.0",
  "info": {
    "description": "Discovery layer unificada da Prefeitura do Rio de Janeiro. Indexa serviços públicos, cursos, vagas e oportunidades MEI com busca full-text e recomendação personalizada por perfil de cidadão.",
    "title": "app-catalogo",
    "contact": {
      "name": "Prefeitura do Rio de Janeiro",
      "url": "https://github.com/prefeitura-rio/app-catalogo"
    },
    "version": "1.0"
  },
  "paths": {
    "/api/public/catalog/{id}": {
      "get": {
        "description": "Retorna todos os campos de um item incluindo source_data original.",
        "tags": [
          "catálogo"
        ],
        "summary": "Detalhe de item do catálogo",
        "parameters": [
          {
            "description": "UUID v4 do item",
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/models.CatalogItem"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/public/recommendations": {
      "get": {
        "description": "Recomendações sem autenticação, com scoring neutro. cluster_hint aceita bairro ou faixa etária para leve personalização.",
        "tags": [
          "recomendações"
        ],
        "summary": "Recomendações anônimas",
        "parameters": [
          {
            "description": "Bairro ou faixa etária (ex: Tijuca, 25-34)",
            "name": "cluster_hint",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Tipos: service, course, job, mei_opportunity",
            "name": "types",
            "in": "query",
            "explode": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "description": "Máximo de itens, max 50 (default: 10)",
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "Contexto: homepage, after_search, profile",
            "name": "context",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/models.RecommendationResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/public/search": {
      "get": {
        "description": "Busca por serviços, cursos, vagas e oportunidades MEI. Suporta sintaxe websearch_to_tsquery: aspas para frase exata, - para exclusão, OR para alternativas.",
        "tags": [
          "busca"
        ],
        "summary": "Busca no catálogo",
        "parameters": [
          {
            "description": "Texto livre de busca",
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Tipos: service, course, job, mei_opportunity",
            "name": "types",
            "in": "query",
            "explode": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "description": "Página (default: 1)",
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "Itens por página, máximo 100 (default: 10)",
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "Modalidade: presencial, digital, hibrido",
            "name": "modalidade",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Bairro do Rio de Janeiro",
            "name": "bairro",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Órgão ou secretaria responsável",
            "name": "orgao",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "[course] Apenas cursos gratuitos",
            "name": "gratuito",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "description": "[course] Turno: matutino, vespertino, noturno",
            "name": "turno",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "[job] Regime: CLT, PJ, temporario",
            "name": "regime_contratacao",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "[job] Modelo: presencial, remoto, hibrido",
            "name": "modelo_trabalho",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "[job] Apenas vagas exclusivas para PCD",
            "name": "pcd",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "description": "[job] Faixa salarial: ate-2sm, 2-4sm, acima-4sm",
            "name": "faixa_salarial",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "[service] Canal: presencial, digital, telefone",
            "name": "canal_atendimento",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "[service] Tema do serviço",
            "name": "tema",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "[mei_opportunity] Segmento do negócio",
            "name": "segmento",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/models.SearchResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/admin/sync/status": {
      "get": {
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "description": "Retorna o último evento de sincronização por fonte de dados. Requer role admin ou go:admin.",
        "tags": [
          "admin"
        ],
        "summary": "Status das sincronizações",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/models.SyncStatus"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/admin/sync/trigger": {
      "post": {
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "description": "Dispara sync ad-hoc em background. Retorna imediatamente. Requer role admin ou go:admin.",
        "tags": [
          "admin"
        ],
        "summary": "Dispara sincronização manual",
        "parameters": [
          {
            "description": "Fonte: salesforce, app-go-api, typesense. Vazio = todas.",
            "name": "source",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
