# Application
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=debug

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_REQUEST_TIMEOUT=30

# Database (PostgreSQL + pgvector)
DB_HOST=localhost
DB_PORT=5433
DB_USER=catalogo
DB_PASSWORD=catalogo
DB_NAME=catalogo
DB_SSL_MODE=disable
DB_TIMEZONE=America/Sao_Paulo
DB_MAX_OPEN_CONNS=25
DB_MIN_CONNS=5

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2

# Migrations
RUN_MIGRATIONS=false

# OpenTelemetry / SigNoz
TRACING_ENABLED=false
TRACING_ENDPOINT=localhost:4317
TRACING_SERVICE_NAME=app-catalogo
TRACING_SERVICE_VERSION=v1.0.0

# Keycloak (service account para chamadas a app-rmi e app-go-api)
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# app-rmi (dados do cidadão)
RMI_BASE_URL=

# app-go-api (cursos, vagas, MEI)
APP_GO_API_BASE_URL=

# SalesForce (Carta de Serviços)
SALESFORCE_INSTANCE_URL=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_WEBHOOK_SECRET=
SALESFORCE_SYNC_INTERVAL=15m
SALESFORCE_OBJECT_TYPE=Service__c

# Sincronização app-go-api
APP_GO_API_SYNC_INTERVAL=30m
APP_GO_API_SYNC_ENABLED=true

# Perfil do cidadão
CITIZEN_PROFILE_STALE_THRESHOLD=1h
CITIZEN_PROFILE_SYNC_INTERVAL=24h

# Cache TTLs
CACHE_SEARCH_TTL=60s
CACHE_RECOMMENDATION_AUTHENTICATED_TTL=5m
CACHE_RECOMMENDATION_CLUSTER_TTL=15m

# CPF hash salt (mínimo 32 caracteres, rotacionar com cuidado)
CPF_HASH_SALT=

# Swagger
SWAGGER_HOST=localhost:8080

# Heimdall (roles do usuário)
HEIMDALL_BASE_URL=
